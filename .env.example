# Copy to .env and fill in. NEVER commit .env.
#
# NOTE: This server uses the return-prompts pattern — it does NOT call any
# LLM API itself. The calling Claude (claude.ai web/mobile or Claude Code)
# does all generation using its own subscription. No ANTHROPIC_API_KEY needed.

# ─── HTTP MCP server config ───
HOST=0.0.0.0
PORT=8050
PUBLIC_URL=https://design-mcp.leadloom.com.au  # for displaying in tool responses

# ─── Auth: per-user tokens ───
# Token DB lives in DO PG 17 (new table design_mcp_tokens)
TOKEN_DB_HOST=170.64.179.248
TOKEN_DB_PORT=5432
TOKEN_DB_NAME=acquirely_rel
TOKEN_DB_USER=postgres
TOKEN_DB_PASSWORD=

# ─── Bitbucket — where to push designs ───
DESIGN_REPO_SSH=git@bitbucket.org:acquirelydev/microsite-design-skills.git
DESIGN_REPO_BRANCH=main
DESIGN_REPO_LOCAL_CLONE=/Users/sgb_m2/microsite-design-skills  # local working copy on the host

# ─── Stock-photo providers (search_stock_images) ───
# Pexels free tier: 200 req/h, 20k/month. Header: Authorization: <key>
PEXELS_API_KEY=
# Unsplash demo tier: 50 req/h. Header: Authorization: Client-ID <key>
# Enables source="unsplash" / source="both" on search_stock_images.
UNSPLASH_ACCESS_KEY=

# ─── Logging ───
LOG_LEVEL=INFO
